REPO_CONTEXT_MAX_TOTAL_BYTES=10485760
REPO_CONTEXT_MAX_README_BYTES=153600
REPO_CONTEXT_MAX_COMMITS=100
REPO_CONTEXT_MAX_ISSUES=100
REPO_CONTEXT_MAX_PULL_REQUESTS=100
REPO_CONTEXT_MAX_CONTRIBUTORS=100
REPO_CONTEXT_MAX_RELEASES=50

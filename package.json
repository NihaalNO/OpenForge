{
  "name": "opensource-compass",
  "version": "0.1.0",
  "private": true,
  "description": "AI-powered developer platform for discovering, understanding, and contributing to open-source GitHub projects.",
  "packageManager": "npm@10.9.0",
  "workspaces": [
    "frontend",
    "backend",
    "shared"
  ],
  "scripts": {
    "dev": "concurrently -n shared,backend,frontend \"npm run dev -w @opensource-compass/shared\" \"npm run dev -w @opensource-compass/backend\" \"npm run dev -w @opensource-compass/frontend\"",
    "dev:frontend": "npm run dev -w @opensource-compass/frontend",
    "dev:backend": "npm run dev -w @opensource-compass/backend",
    "build": "npm run build --workspaces",
    "lint": "npm run lint --workspaces",
    "typecheck": "npm run typecheck --workspaces",
    "test": "npm run test --workspaces",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@typescript-eslint/eslint-plugin": "^8.19.1",
    "@typescript-eslint/parser": "^8.19.1",
    "concurrently": "^9.1.2",
    "eslint": "^9.17.0",
    "eslint-config-next": "^15.1.3",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2"
  }
}
